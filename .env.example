# Root .env — read by Bun (server runtime) and docker-compose (build/runtime
# substitution). Copy to .env and fill in real values.

# Server-side reCAPTCHA v3 secret. Register a site at
# https://www.google.com/recaptcha/admin to get this. Server logs a warning
# and skips verification when unset.
RECAPTCHA_SECRET=
# Optional. Default 0.5. Reject auth when v3 score is below this.
# RECAPTCHA_MIN_SCORE=0.5

# Client-side site key. Read by docker-compose at build time → passed as a
# build-arg into the Dockerfile so Vite bakes it into client/dist. Local dev
# reads VITE_* from client/.env instead (Vite runs from that directory).
VITE_RECAPTCHA_SITE_KEY=

# Runtime-generated server files. In Docker this defaults to the persisted
# evilquest_data volume at /app/data, so forum uploads and baked forum avatars
# survive container rebuilds/restarts.
# PROJECTRS_RUNTIME_DATA_DIR=/app/data

# Left Hand Discord bot. Create a Discord application and bot named
# "Left Hand", then put the bot token here. This value is consumed by the
# left-hand docker-compose service and must stay out of git.
LEFT_HAND_DISCORD_TOKEN=
# Optional. Set a single server/guild ID while developing so slash commands
# appear immediately in that guild.
# LEFT_HAND_DISCORD_GUILD_ID=
# Optional. If true, the bot tries to set its per-server nickname to Left Hand.
# Requires the Manage Nicknames permission in that Discord server.
# LEFT_HAND_SET_NICKNAME=false
# LEFT_HAND_LOG_LEVEL=INFO
# Optional. Defaults to the live EvilQuest API. For local dev against the
# host-running Bun server, use http://host.docker.internal:4000. If EvilQuest
# is running as the docker-compose service instead, use http://evilquest:4000.
# LEFT_HAND_EVILQUEST_API_BASE_URL=https://evilquest.net

# Forum Discord emotes. By default docker-compose reuses the Left Hand bot
# token and guild ID above. DISCORD_TOKEN is also accepted because the bot
# supports that name locally. Set DISCORD_BOT_TOKEN only if the website should
# use a different bot for synced forum emotes.
# DISCORD_TOKEN=
# DISCORD_BOT_TOKEN=
# DISCORD_GUILD_ID=1504534632799010816
# DISCORD_EMOJI_SYNC_INTERVAL_MS=900000

# Trading-post helpers. Item validation reads a read-only local copy of
# server/data/items.json and only exposes safe listing metadata in Discord.
# LEFT_HAND_ITEMS_PATH=/app/game-data/items.json
LEFT_HAND_TRADING_POST_CHANNEL_ID=1504543318401482854
# Number of recent trading-post messages scanned by /trade search.
# LEFT_HAND_TRADE_LISTING_SCAN_LIMIT=100

# Bug report thread automation. In a thread under this parent channel, an
# allowed user can write exactly "fixed" to set "(FIXED) ", "not a bug" to set
# "(NOT A BUG) ", or "reopen" to remove either status prefix. The bot needs
# Message Content Intent enabled in Discord Developer Portal and Manage Threads
# permission in this channel.
LEFT_HAND_BUG_REPORT_AUTOMATION_ENABLED=false
LEFT_HAND_BUG_REPORT_PARENT_CHANNEL_ID=1504718539246800896
LEFT_HAND_FIXED_AUTHOR_USER_IDS=206051525993299968,154607229364862976
# Archive bug threads after setting "(FIXED) " or "(NOT A BUG) ".
# LEFT_HAND_BUG_REPORT_ARCHIVE_ON_STATUS=true
# Number of active/recent archived bug threads scanned by /bugstats and /bugsearch.
# LEFT_HAND_BUG_REPORT_THREAD_SCAN_LIMIT=200
