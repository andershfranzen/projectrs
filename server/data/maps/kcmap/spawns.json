      },
      "dialogue": {
        "root": "greet",
        "nodes": {
          "greet": {
            "id": "greet",
            "lines": [
              "Welcome to my shop, traveler!",
              "What can I do for you today?"
            ],
            "options": [
              {
                "label": "Show me what you've got.",
                "action": {
                  "type": "openShop"
                }
              },
              {
                "label": "Tell me about this place.",
                "next": "lore"
              },
              {
                "label": "Goodbye."
              },
              {
                "label": "About Bob",
                "next": "Bob_s_Burial_stage_0_reply",
                "condition": {
                  "type": "questStage",
                  "questId": "Bob's Burial",
                  "minStage": 0,
                  "maxStage": 0
                }
              }
            ]
          },
          "lore": {
            "id": "lore",
            "lines": [
              "This little shop has been in my family for three generations.",
              "A lot of inexperienced travelers tend to come around these parts. I keep a lot of stuff people would consider basic."
            ],
            "options": [
              {
                "label": "Show me your wares.",
                "action": {
                  "type": "openShop"
                }
              },
              {
                "label": "Back.",
                "next": "greet"
              }
            ]
          },
          "Bob_s_Burial_stage_0_reply": {
            "id": "Bob_s_Burial_stage_0_reply",
            "lines": [
              "Oh its horrible, apparently some insane person walked into the cow pen and just slew ol' Bob.",
              "Heard the farmer down south west saw it all happen, hopefully he can describe the killer so Bob can get justice!"
            ],
            "options": [
              {
                "label": "Continue."
              }
            ]
          }
        }
      },
      "name": "Robert"
    },
