# Vite-baked env vars (must start with VITE_ to be exposed to client code).
# Copy to client/.env and fill in real values.

# reCAPTCHA v3 site key — pair with RECAPTCHA_SECRET in the server .env.
# When unset, client skips the script load and submits without a token;
# server matches by skipping verification when its own secret is unset.
VITE_RECAPTCHA_SITE_KEY=
